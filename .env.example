# Copy to .env and fill in values.

# Required for AI features (profile, match, resume, cover letter)
OPENAI_API_KEY=

# Optional: protect the FastAPI app — same value must be set here and in Streamlit .env
# Streamlit sends header X-Api-Key automatically when JOB_HUNTER_API_KEY is set.
JOB_HUNTER_API_KEY=

# If 1, API exits at startup unless JOB_HUNTER_API_KEY is set (use on shared networks / servers)
REQUIRE_JOB_HUNTER_API_KEY=0

# If production, JOB_HUNTER_API_KEY is required (same as REQUIRE_JOB_HUNTER_API_KEY=1)
# ENVIRONMENT=development

# Optional API base URL for Streamlit (default http://127.0.0.1:8000).
# You can also set API_URL in .streamlit/secrets.toml (see secrets.toml.example).
API_URL=http://127.0.0.1:8000

# Optional: HTTP timeouts for server-side requests to the API (Render cold starts).
# API_CONNECT_TIMEOUT=25
# API_READ_TIMEOUT=300

# Optional: retry POST on 502/503/504 (free-tier cold start). Default 2.
# API_GATEWAY_RETRIES=2

# Max upload size in bytes (default 15 MB)
MAX_UPLOAD_BYTES=15728640

# Comma-separated origins for Streamlit CORS
CORS_ORIGINS=http://127.0.0.1:8501,http://localhost:8501

# Optional: SerpApi (Google Jobs) for broad job discovery in POST /job-search
# https://serpapi.com/manage-api-key
# SERPAPI_API_KEY=

# Optional caps for /job-search (defaults shown)
# JOB_SEARCH_MAX_LISTINGS=40
# JOB_SEARCH_MAX_PER_RSS=15
# JOB_SEARCH_MAX_RANK=20
# JOB_FETCH_MAX_BYTES=2097152
# JOB_RSS_MAX_BYTES=3145728
