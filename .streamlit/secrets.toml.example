# Copy to ".streamlit/secrets.toml" (gitignored) for local Streamlit runs.
# Values here override missing API_URL from the process environment.

API_URL = "http://127.0.0.1:8000"

# Optional: same as .env — must match the API when REQUIRE_JOB_HUNTER_API_KEY=1
# JOB_HUNTER_API_KEY = "your-shared-secret"
